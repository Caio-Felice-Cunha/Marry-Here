# Copy to .env and adjust for your environment. Do not commit .env.
# All values have safe development defaults in core/settings.py, so the
# app runs without a .env file. Set these for any non-local deployment.

# Django secret key. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=django-insecure-dev-only-change-me-0123456789abcdef

# Turn off in production.
DJANGO_DEBUG=True

# Comma-separated hostnames allowed to serve the app (required when DEBUG=False).
DJANGO_ALLOWED_HOSTS=

# Base URL used to build absolute invitation links shown on the guest list.
SITE_URL=http://127.0.0.1:8000
